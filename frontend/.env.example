# Локальный порт, на котором будет доступен фронт после `docker compose up`
FRONTEND_PORT=3000

# URL бэкенда из контейнера. Для Docker Desktop работает host.docker.internal.
# Если у вас Linux + бэкенд на хосте — используйте http://172.17.0.1:8080
# Если бэкенд тоже в Docker и в той же сети — http://backend:8080
BACKEND_URL=http://host.docker.internal:8080
