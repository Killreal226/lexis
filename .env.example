
# --- Frontend ---
FRONTEND_PORT=3000

# --- Postgres ---
DB_USER=lexis
DB_PASSWORD=lexis
DB_NAME=lexis
DB_PORT_HOST=5432

# --- Backend ---
JWT_SECRET=lexis-jwt-secret
JWT_ACCESS_TTL=168h

# Применить демо-сиды (5 пользователей, 11 слов, 13 progress-записей)
# при первом старте. Безопасно ставить true только на чистой БД.
RUN_SEEDS=false

# Импорт каталога слов из data/words.csv при старте бэкенда.
# Идемпотентен: если в БД уже есть общие слова (created_by IS NULL) — no-op.
IMPORT_WORDS=true


STORAGE_PATH=storage/images